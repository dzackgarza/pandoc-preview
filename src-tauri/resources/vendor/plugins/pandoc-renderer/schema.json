{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "pandoc-renderer config section",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "command",
    "style"
  ],
  "properties": {
    "command": {
      "type": "string",
      "minLength": 1
    },
    "style": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "figure_width"
      ],
      "properties": {
        "figure_width": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
