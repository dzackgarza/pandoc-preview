{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Pandoc Preview",
  "version": "0.1.0",
  "identifier": "com.dzackgarza.pandocpreview",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Pandoc Preview",
        "width": 1440,
        "height": 920,
        "minWidth": 800,
        "minHeight": 500
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "rpm", "appimage"],
    "resources": ["resources/mathjax/tex-full-svg-a11y.min.js"],
    "icon": ["icons/32x32.png", "icons/128x128.png", "icons/128x128@2x.png", "icons/icon.ico", "icons/icon.png"]
  }
}
