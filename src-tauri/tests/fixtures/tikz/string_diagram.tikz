\begin{tikzpicture}
	\path [use as bounding box] (-1.5, -1.5) rectangle (1.5, 1.5);
	\begin{pgfonlayer}{nodelayer}
		\node [style=red node] (0) at (0, 1) {};
		\node [style=blue node 2] (1) at (1, 0) {};
		\node [style=blue node] (2) at (-1, 0) {};
		\node [style=yellow square] (3) at (0, -1) {foo};
		\node [style=none] (4) at (0, -1.5) {$\bar{x}$};
	\end{pgfonlayer}
	\begin{pgfonlayer}{edgelayer}
		\draw [style=in-out, in=-90, out=0] (3) to (1);
		\draw [style=bent, bend right] (3) to (2);
		\draw (2) to (0);
		\draw (0) to (1);
		\draw [style=plain] (3) to (4);
	\end{pgfonlayer}
\end{tikzpicture}
